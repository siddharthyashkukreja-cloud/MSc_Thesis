\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{setup}[2026/05/30 Clean Thesis Style]

% -------------------------------------------------------------------
% BASIC PAGE AND FONT SETUP
% -------------------------------------------------------------------
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage[british]{babel}
\usepackage[left=2.5cm,right=2.5cm,top=2.5cm,bottom=2.5cm]{geometry}
\usepackage{microtype}
\usepackage{setspace}

% Optional but recommended: more journal-like font
\usepackage[default]{sourcesanspro}

% -------------------------------------------------------------------
% COLOURS AND GRAPHICS
% -------------------------------------------------------------------
\usepackage[dvipsnames]{xcolor}
\usepackage{graphicx}
\usepackage{grffile}
\usepackage{tikz}
\usepackage{float}
\usepackage{rotating}
\usepackage{lscape}
\usepackage{pdflscape}
\usepackage[section]{placeins}
\usepackage{hyperref}

% -------------------------------------------------------------------
% MATH AND TABLES
% -------------------------------------------------------------------
\usepackage{amsmath,amssymb}
\usepackage{booktabs}
\usepackage{array}
\usepackage{dcolumn}
\usepackage{longtable}
\usepackage{threeparttable}

% -------------------------------------------------------------------
% CAPTIONS AND SUBFIGURES
% -------------------------------------------------------------------
\usepackage[
    font=small,
    labelfont=bf,
    justification=justified,
    singlelinecheck=false,
    format=plain
]{caption}

\usepackage{subfig}
\captionsetup[subfloat]{position=bottom}
\captionsetup[figure]{labelfont={bf}, justification=centering}
\captionsetup[table]{labelfont={bf}, justification=justified}

% -------------------------------------------------------------------
% BIBLIOGRAPHY AND LINKS
% -------------------------------------------------------------------
\usepackage{natbib}
\usepackage[
    colorlinks=true,
    linkcolor=black,
    citecolor=black,
    urlcolor=black,
    filecolor=black,
    bookmarks=true,
    pagebackref=true
]{hyperref}
\usepackage{url}

% -------------------------------------------------------------------
% HEADERS AND PAGE STYLE
% -------------------------------------------------------------------
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% -------------------------------------------------------------------
% SECTION AND CHAPTER FORMATTING
% -------------------------------------------------------------------
\usepackage{titlesec}

% Chapter: compact, single-line, not oversized
\titleformat{\chapter}[hang]
  {\normalfont\bfseries\fontsize{16}{18}\selectfont}
  {\thechapter}{0.65em}{}

\titlespacing*{\chapter}
  {0pt}{-6pt}{8pt}

% Section: clear but restrained
\titleformat{\section}[hang]
  {\normalfont\bfseries\fontsize{13}{15}\selectfont}
  {\thesection}{0.65em}{}

\titlespacing*{\section}
  {0pt}{10pt}{4pt}

% Subsection: modest hierarchy step
\titleformat{\subsection}[hang]
  {\normalfont\bfseries\fontsize{11.5}{13}\selectfont}
  {\thesubsection}{0.65em}{}

\titlespacing*{\subsection}
  {0pt}{8pt}{2pt}
% -------------------------------------------------------------------
% LISTS AND MISC
% -------------------------------------------------------------------
\usepackage{enumitem}
\setlist{nosep}
\usepackage{verbatim}

% -------------------------------------------------------------------
% HYPHENATION / WIDOWS / ORPHANS
% -------------------------------------------------------------------
\clubpenalty=10000
\widowpenalty=10000
\displaywidowpenalty=10000

